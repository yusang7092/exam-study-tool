# Supabase project URL (e.g. https://xyzxyzxyz.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — allows bypassing RLS (keep secret, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Allowed CORS origin (e.g. your Vercel deployment URL). Defaults to http://localhost:5173
ALLOWED_ORIGIN=https://your-app.vercel.app
